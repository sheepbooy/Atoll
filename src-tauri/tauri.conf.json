{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atoll",
  "version": "0.1.0",
  "identifier": "com.atoll.agentisland",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Atoll",
        "label": "main",
        "width": 680,
        "height": 430,
        "minWidth": 320,
        "minHeight": 120,
        "center": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
